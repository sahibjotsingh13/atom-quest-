// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// CORE TABLES
// ============================================

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  employeeId   String      @unique
  firstName    String
  lastName     String
  role         UserRole
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  managerId    String?
  manager      User?       @relation("ManagerRelation", fields: [managerId], references: [id])
  reports      User[]      @relation("ManagerRelation")
  azureAdId    String?     @unique
  isActive     Boolean     @default(true)

  goalSheets     GoalSheet[]
  approvedSheets GoalSheet[]    @relation("ApprovedBy")
  lockedSheets   GoalSheet[]    @relation("LockedBy")
  sharedGoals    Goal[]         @relation("SharedBy")
  checkIns       CheckIn[]
  auditLogs      AuditLog[]
  notifications  Notification[]

  escalationsFor      Escalation[] @relation("EscalatedFor")
  escalationsBy       Escalation[] @relation("EscalatedBy")
  resolvedEscalations Escalation[] @relation("ResolvedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  employee
  manager
  admin
}

model Department {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  parentId    String?
  parent      Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DeptHierarchy")
  users       User[]
  thrustAreas ThrustArea[]
  createdAt   DateTime     @default(now())
}

model Cycle {
  id               String      @id @default(uuid())
  name             String
  fiscalYear       String
  goalSettingStart DateTime
  goalSettingEnd   DateTime
  q1Start          DateTime
  q1End            DateTime
  q2Start          DateTime
  q2End            DateTime
  q3Start          DateTime
  q3End            DateTime
  q4Start          DateTime
  q4End            DateTime
  status           CycleStatus @default(active)

  goalSheets GoalSheet[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum CycleStatus {
  draft
  active
  closed
  archived
}

model ThrustArea {
  id           String      @id @default(uuid())
  name         String
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  goals        Goal[]
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
}

model UomType {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  description   String?
  formulaType   String
  displayFormat String?
  goals         Goal[]
  createdAt     DateTime @default(now())
}

model GoalSheet {
  id              String      @id @default(uuid())
  employeeId      String
  employee        User        @relation(fields: [employeeId], references: [id])
  cycleId         String
  cycle           Cycle       @relation(fields: [cycleId], references: [id])
  status          SheetStatus @default(draft)
  totalWeightage  Decimal     @default(0) @db.Decimal(5, 2)
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedById    String?
  approvedBy      User?       @relation("ApprovedBy", fields: [approvedById], references: [id])
  rejectionReason String?
  lockedAt        DateTime?
  lockedById      String?
  lockedBy        User?       @relation("LockedBy", fields: [lockedById], references: [id])

  goals Goal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, cycleId])
}

enum SheetStatus {
  draft
  submitted
  under_review
  approved
  rejected
  locked
}

model Goal {
  id           String     @id @default(uuid())
  goalSheetId  String
  goalSheet    GoalSheet  @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)
  thrustAreaId String
  thrustArea   ThrustArea @relation(fields: [thrustAreaId], references: [id])
  title        String
  description  String?
  uomTypeId    String
  uomType      UomType    @relation(fields: [uomTypeId], references: [id])
  targetValue  Decimal?   @db.Decimal(15, 4)
  targetDate   DateTime?
  weightage    Decimal    @db.Decimal(5, 2)
  status       GoalStatus @default(not_started)

  isShared     Boolean @default(false)
  parentGoalId String?
  parentGoal   Goal?   @relation("SharedGoalRelation", fields: [parentGoalId], references: [id])
  childGoals   Goal[]  @relation("SharedGoalRelation")
  sharedById   String?
  sharedBy     User?   @relation("SharedBy", fields: [sharedById], references: [id])

  actualValue           Decimal?  @db.Decimal(15, 4)
  actualDate            DateTime?
  achievementPercentage Decimal?  @db.Decimal(5, 2)
  progressScore         Decimal?  @db.Decimal(5, 2)

  q1Actual  Decimal? @db.Decimal(15, 4)
  q1Status  String?
  q1Comment String?
  q2Actual  Decimal? @db.Decimal(15, 4)
  q2Status  String?
  q2Comment String?
  q3Actual  Decimal? @db.Decimal(15, 4)
  q3Status  String?
  q3Comment String?
  q4Actual  Decimal? @db.Decimal(15, 4)
  q4Status  String?
  q4Comment String?

  checkIns CheckIn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GoalStatus {
  not_started
  on_track
  completed
  at_risk
  delayed
}

model CheckIn {
  id                String        @id @default(uuid())
  goalId            String
  goal              Goal          @relation(fields: [goalId], references: [id], onDelete: Cascade)
  quarter           Quarter
  checkInDate       DateTime      @default(now())
  plannedTarget     Decimal?      @db.Decimal(15, 4)
  actualAchievement Decimal?      @db.Decimal(15, 4)
  actualDate        DateTime?
  status            CheckInStatus
  employeeComment   String?
  managerComment    String?
  managerId         String?
  manager           User?         @relation(fields: [managerId], references: [id])
  isAcknowledged    Boolean       @default(false)
  acknowledgedAt    DateTime?

  createdAt DateTime @default(now())

  @@unique([goalId, quarter], name: "goalId_quarter")
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum CheckInStatus {
  not_started
  on_track
  completed
  at_risk
}

model AuditLog {
  id           String   @id @default(uuid())
  tableName    String
  recordId     String
  action       String
  changedById  String
  changedBy    User     @relation(fields: [changedById], references: [id])
  changedAt    DateTime @default(now())
  oldValues    Json?
  newValues    Json?
  changeReason String?
  ipAddress    String?
  userAgent    String?
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  category  String    @default("system")
  title     String
  message   String
  deepLink  String?
  metadata  Json?
  isRead    Boolean   @default(false)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model EscalationRule {
  id               String       @id @default(uuid())
  name             String
  triggerCondition String
  daysThreshold    Int
  escalationLevel  Int          @default(1)
  notifyRole       String
  templateSubject  String?
  templateBody     String?
  isActive         Boolean      @default(true)
  escalations      Escalation[]
  createdAt        DateTime     @default(now())
}

model Escalation {
  id              String         @id @default(uuid())
  ruleId          String
  triggeredForId  String
  triggeredById   String?
  resolvedById    String?
  escalationLevel Int
  status          String         @default("open")
  triggeredAt     DateTime       @default(now())
  resolvedAt      DateTime?
  resolutionNotes String?

  rule            EscalationRule @relation(fields: [ruleId], references: [id])
  triggeredFor    User           @relation("EscalatedFor", fields: [triggeredForId], references: [id])
  triggeredBy     User?          @relation("EscalatedBy", fields: [triggeredById], references: [id])
  resolvedBy      User?          @relation("ResolvedBy", fields: [resolvedById], references: [id])
}

